<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>   <thead> <tr class="over_header"> <th aria-label=" " data-stat="header_empty_0" colspan="8" class=" poptip over_header center"></th> <th aria-label="Passing" data-stat="header_pass" colspan="23" class=" poptip over_header center">Passing</th> <th aria-label=" " data-stat="header_empty_2" colspan="3" class=" poptip over_header center"></th> </tr> <tr> <th aria-label="Rk" data-stat="ranker" scope="col" class="ranker poptip center" data-tip="Rank">Rk</th> <th aria-label="Player" data-stat="name_display" scope="col" class=" poptip sort_default_asc center">Player</th> <th aria-label="Cmp" data-stat="pass_cmp" scope="col" class=" poptip sort_col center" data-tip="Passes completed">Cmp</th> <th aria-label="Season" data-stat="year_id" scope="col" class=" poptip center">Season</th> <th aria-label="Age" data-stat="age" scope="col" class=" poptip center" data-tip="As of Dec. 31 of the season in question.">Age</th> <th aria-label="Team" data-stat="teams_played_for" scope="col" class=" poptip center">Team</th> <th aria-label="G" data-stat="games" scope="col" class=" poptip center" data-tip="Games played">G</th> <th aria-label="GS" data-stat="games_started" scope="col" class=" poptip center" data-tip="Games started as an offensive or defensive player">GS</th> <th aria-label="Cmp" data-stat="pass_cmp" scope="col" class=" poptip center" data-tip="Passes completed">Cmp</th> <th aria-label="Att" data-stat="pass_att" scope="col" class=" poptip center" data-tip="Passes attempted">Att</th> <th aria-label="Inc" data-stat="pass_inc" scope="col" class=" poptip center" data-tip="Passes incomplete (attempts-completions)">Inc</th> <th aria-label="Cmp%" data-stat="pass_cmp_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of Passes Completed&lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">Cmp%</th> <th aria-label="Yds" data-stat="pass_yds" scope="col" class=" poptip center" data-tip="Yards Gained by Passing&lt;br&gt;For teams, sack yardage is deducted from this total">Yds</th> <th aria-label="TD" data-stat="pass_td" scope="col" class=" poptip center" data-tip="Passing Touchdowns">TD</th> <th aria-label="Int" data-stat="pass_int" scope="col" class=" poptip center" data-tip="Interceptions thrown">Int</th> <th aria-label="Pick6" data-stat="pass_int_td" scope="col" class=" poptip center" data-tip="Interceptions thrown by this quarterback and returned for a touchdown (since 1950)">Pick6</th> <th aria-label="TD%" data-stat="pass_td_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of Touchdowns Thrown when Attempting to Pass &lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader" data-filter="1" data-name="">TD%</th> <th aria-label="Int%" data-stat="pass_int_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of Times Intercepted when Attempting to Pass &lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader.&lt;br /&gt;" data-filter="1" data-name="">Int%</th> <th aria-label="Rate" data-stat="pass_rating" scope="col" class=" poptip hide_non_quals center" data-tip="Passer Rating, &lt;a href='https://www.pro-football-reference.com/about/glossary.htm'&gt;see glossary&lt;/a&gt; for details&lt;br&gt;Different ratings are used by the NFL and NCAA.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader, minimum 150 pass attempts for playoffs leader." data-filter="1" data-name="">Rate</th> <th aria-label="Sk" data-stat="pass_sacked" scope="col" class=" poptip center" data-tip="Times sacked (first recorded in 1969, player per game since 1981)">Sk</th> <th aria-label="Yds" data-stat="pass_sacked_yds" scope="col" class=" poptip center" data-tip="Yards lost due to sacks (first recorded in 1969, player per game since 1981)">Yds</th> <th aria-label="Sk%" data-stat="pass_sacked_pct" scope="col" class=" poptip hide_non_quals center" data-tip="Percentage of Time Sacked when Attempting to Pass: Times Sacked / (Passes Attempted + Times Sacked)&lt;br&gt;Minimum 14 attempts + sacks per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader" data-filter="1" data-name="">Sk%</th> <th aria-label="Y/A" data-stat="pass_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="Yards gained per pass attempt &lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">Y/A</th> <th aria-label="AY/A" data-stat="pass_adj_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="Adjusted Yards gained per pass attempt&lt;br /&gt;(Passing Yards + 20 * Passing TD - 45 * Interceptions) / (Passes Attempted)&lt;br /&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">AY/A</th> <th aria-label="ANY/A" data-stat="pass_adj_net_yds_per_att" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Adjusted Net Yards per Pass Attempt&lt;/b&gt;&lt;br&gt;(Passing Yards - Sack Yards + (20 * Passing TD) - (45 * Interceptions)) / (Passes Attempted + Times Sacked)&lt;br&gt;Minimum 14 attempts per scheduled game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader." data-filter="1" data-name="">ANY/A</th> <th aria-label="Y/C" data-stat="pass_yds_per_cmp" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Yards gained per pass completion&lt;/b&gt; (Passing Yards) / (Passes Completed)&lt;br /&gt;Minimum 14 pass attempts per schedule game to qualify as leader.&lt;br /&gt;Minimum 1500 pass attempts to qualify as career leader" data-filter="1" data-name="">Y/C</th> <th aria-label="Y/G" data-stat="pass_yds_per_g" scope="col" class=" poptip hide_non_quals center" data-tip="&lt;b&gt;Yards gained per game played&lt;/b&gt;&lt;br&gt;Minimum half a game played per scheduled game to qualify as leader.&lt;br&gt;Minimum 1500 pass attempts to qualify as career leader" data-filter="1" data-name="">Y/G</th> <th aria-label="Succ%" data-stat="pass_success" scope="col" class=" poptip hide_non_quals center" data-tip="Passing Success Rate&lt;br /&gt;A successful pass gains at least 40% of yards required on 1st down, 60% of yards required on 2nd down, and 100% on 3rd or 4th down. Denominator is pass attempts + times sacked." data-filter="1" data-name="">Succ%</th> <th aria-label="W" data-stat="qb_w" scope="col" class=" poptip center" data-tip="Team wins in games started by this QB (regular season)">W</th> <th aria-label="L" data-stat="qb_l" scope="col" class=" poptip center" data-tip="Team losses in games started by this QB (regular season)">L</th> <th aria-label="T" data-stat="qb_t" scope="col" class=" poptip center" data-tip="Team ties in games started by this QB (regular season)">T</th> <th aria-label="4QC" data-stat="comebacks" scope="col" class=" poptip center" data-tip="Comebacks led by quarterback.&lt;br /&gt;Must be an offensive scoring drive in the 4th quarter, with the team trailing by one score, though not necessarily a drive to take the lead. Only games ending in a win or tie are included.">4QC</th> <th aria-label="GWD" data-stat="gwd" scope="col" class=" poptip center" data-tip="Game-winning drives led by quarterback.&lt;br /&gt;Must be an offensive scoring drive in the 4th quarter or overtime that puts the winning team ahead for the last time.">GWD</th> <th aria-label="Pos" data-stat="pos" scope="col" class=" poptip center" data-tip="Position">Pos</th> </tr> </thead> <tbody><tr data-row="0"> <th scope="row" class="right " data-stat="ranker" csk="1">1</th> <td class="left " data-append-csv="BradTo00" data-stat="name_display" csk="Brady Tom">Tom Brady</td> <td class="right " data-stat="pass_cmp">490</td> <td class="left " data-stat="year_id" csk="2022">2022</td> <td class="right " data-stat="age">45</td> <td class="left " data-stat="teams_played_for">TAM</td> <td class="right " data-stat="games">17</td> <td class="right " data-stat="games_started">17</td> <td class="right " data-stat="pass_cmp">490</td> <td class="right " data-stat="pass_att">733</td> <td class="right " data-stat="pass_inc">243</td> <td class="right " data-stat="pass_cmp_pct" csk="0.6684856753">66.8</td> <td class="right " data-stat="pass_yds">4694</td> <td class="right " data-stat="pass_td">25</td> <td class="right " data-stat="pass_int">9</td> <td class="right iz" data-stat="pass_int_td">0</td> <td class="right " data-stat="pass_td_pct" csk="0.0341064120">3.4</td> <td class="right " data-stat="pass_int_pct" csk="0.0122783083">1.2</td> <td class="right " data-stat="pass_rating" csk="90.7">90.7</td> <td class="right " data-stat="pass_sacked">22</td> <td class="right " data-stat="pass_sacked_yds">160</td> <td class="right " data-stat="pass_sacked_pct" csk="0.0291390728">2.91</td> <td class="right " data-stat="pass_yds_per_att" csk="6.4038199181">6.4</td> <td class="right " data-stat="pass_adj_yds_per_att" csk="6.53342428377">6.5</td> <td class="right " data-stat="pass_adj_net_yds_per_att" csk="6.13112582781">6.1</td> <td class="right " data-stat="pass_yds_per_cmp" csk="9.5795918367">9.6</td> <td class="right " data-stat="pass_yds_per_g" csk="276.1176470588">276.1</td> <td class="right " data-stat="pass_success" csk="0.4953